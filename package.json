{
  "name": "a2me-mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing read-only A2Me family-context tools for AI assistants",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --write .",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "a2me",
    "family",
    "context"
  ],
  "author": "Kinnectd LLC",
  "license": "MIT",
  "homepage": "https://a2me.app/features/ai-integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kinnectd/a2me-mcp-server.git"
  },
  "private": true,
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
