# --- kinnectd-api (the data source) ---
A2ME_API_URL=http://localhost:8080/api
A2ME_AUTH_TOKEN=mock-dev-token
# A2ME_USE_MOCK=false   # uncomment to call the real API instead of mock data

# --- transport ---
MCP_SERVER_PORT=3100
# MCP_TRANSPORT=http               # 'stdio' (default) or 'http' (remote, for the OAuth flow)
# MCP_PUBLIC_URL=https://dev.mcp.a2me.app   # public URL = resource + token audience

# --- auth (Scalekit) ---
# MCP_AUTH_PROVIDER=scalekit        # 'dev' (default, forwards bearer unverified) or 'scalekit'
# MCP_AUTH_ISSUER=https://kinnectd.scalekit.dev/resources/res_130696843431510786
# MCP_AUTH_AUDIENCE=https://dev.mcp.a2me.app   # defaults to MCP_PUBLIC_URL if unset
